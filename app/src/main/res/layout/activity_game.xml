<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- ── Top Bar ─────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/bg_surface"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="16dp"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnHamburger"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_menu"
            android:contentDescription="메뉴"
            android:tint="@color/text_primary" />

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:fontFamily="monospace"
            android:layout_marginEnd="16dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="💣" android:textSize="18sp" android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/tvMineCount"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textColor="@color/accent"
                android:textSize="18sp" android:fontFamily="monospace"
                android:minWidth="36dp" android:gravity="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── Left Dimension Slider Panel ────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/leftPanel"
        android:layout_width="52dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:background="@color/bg_surface"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent">

        <!-- 최고 차원 라벨 -->
        <TextView
            android:id="@+id/labelDimTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4D"
            android:textColor="@color/accent"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <!-- 세로 슬라이더: max=2 → 위=4D, 중=3D, 아래=2D -->
        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="0dp"
            android:layout_weight="1">
            <SeekBar
                android:id="@+id/seekDimension"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:rotation="270"
                android:max="2"
                android:progress="2"
                android:progressTint="@color/accent"
                android:thumbTint="@color/accent"
                android:layout_gravity="center" />
        </FrameLayout>

        <!-- 최저 차원 라벨 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2D"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- ── Right Layer Slider Panel ────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/rightPanel"
        android:layout_width="52dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:background="@color/bg_surface"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 현재 레이어 축 라벨 -->
        <TextView
            android:id="@+id/tvLayerAxis"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="w"
            android:textColor="@color/accent_flag"
            android:textSize="10sp"
            android:layout_marginBottom="2dp" />

        <!-- 현재 레이어 번호 -->
        <TextView
            android:id="@+id/tvLayerNum"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/accent_flag"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <!-- 세로 레이어 슬라이더 -->
        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="0dp"
            android:layout_weight="1">
            <SeekBar
                android:id="@+id/seekLayer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:rotation="270"
                android:max="0"
                android:progress="0"
                android:progressTint="@color/accent_flag"
                android:thumbTint="@color/accent_flag"
                android:layout_gravity="center" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/text_disabled"
            android:textSize="9sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- ── Game Canvas ─────────────────────────────────────────────────── -->
    <com.minesweeper4d.GameView
        android:id="@+id/gameView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toEndOf="@id/leftPanel"
        app:layout_constraintEnd_toStartOf="@id/rightPanel" />

    <!-- ── Bottom Tool Bar ─────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:background="@color/bg_surface"
        android:orientation="horizontal"
        android:gravity="center"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/btnDig"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:background="?attr/selectableItemBackground" android:padding="8dp">
            <TextView android:id="@+id/iconDig"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⛏" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="파기" android:textColor="@color/text_secondary"
                android:textSize="11sp" android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnFlag"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:background="?attr/selectableItemBackground" android:padding="8dp">
            <TextView android:id="@+id/iconFlag"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⚑" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="깃발" android:textColor="@color/text_secondary"
                android:textSize="11sp" android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnRange"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:background="?attr/selectableItemBackground" android:padding="8dp">
            <TextView android:id="@+id/iconRange"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔍" android:textSize="26sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="범위" android:textColor="@color/text_secondary"
                android:textSize="11sp" android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── Exit Overlay ────────────────────────────────────────────────── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/exitOverlay"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#CC000000" android:visibility="gone"
        android:clickable="true" android:focusable="true"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout
            android:layout_width="280dp" android:layout_height="wrap_content"
            android:background="@drawable/bg_dialog" android:orientation="vertical"
            android:padding="24dp" android:gravity="center"
            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="메뉴로 돌아가시겠습니까?" android:textColor="@color/text_primary"
                android:textSize="16sp" android:gravity="center" android:layout_marginBottom="24dp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center">
                <Button android:id="@+id/btnExitNo"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="아니오" android:textColor="@color/text_primary"
                    android:backgroundTint="@color/bg_card" android:layout_marginEnd="8dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                <Button android:id="@+id/btnExitYes"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="예" android:textColor="@color/bg_primary"
                    android:backgroundTint="@color/accent" android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ── FAIL Overlay ────────────────────────────────────────────────── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/failOverlay"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#CC000000" android:visibility="gone"
        android:clickable="true" android:focusable="true"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout
            android:layout_width="240dp" android:layout_height="wrap_content"
            android:background="@drawable/bg_dialog" android:orientation="vertical"
            android:padding="32dp" android:gravity="center"
            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="FAIL" android:textColor="@color/accent_danger"
                android:textSize="48sp" android:textStyle="bold" android:layout_marginBottom="24dp" />
            <Button android:id="@+id/btnFailMenu"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="메뉴로" android:textColor="@color/bg_primary"
                android:backgroundTint="@color/accent_danger" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ── WIN Overlay ─────────────────────────────────────────────────── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/winOverlay"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#CC000000" android:visibility="gone"
        android:clickable="true" android:focusable="true"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout
            android:layout_width="240dp" android:layout_height="wrap_content"
            android:background="@drawable/bg_dialog" android:orientation="vertical"
            android:padding="32dp" android:gravity="center"
            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="WIN" android:textColor="@color/accent_win"
                android:textSize="48sp" android:textStyle="bold" />
            <TextView android:id="@+id/tvWinTime"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="" android:textColor="@color/text_secondary"
                android:textSize="16sp" android:fontFamily="monospace"
                android:layout_marginTop="8dp" android:layout_marginBottom="24dp" />
            <Button android:id="@+id/btnWinMenu"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="메뉴로" android:textColor="@color/bg_primary"
                android:backgroundTint="@color/accent_win" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
